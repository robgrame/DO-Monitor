{
  "bindings": [
    {
      "authLevel": "function",
      "type": "httpTrigger",
      "direction": "in",
      "name": "Request",
      "methods": [ "post" ]
    },
    {
      "type": "http",
      "direction": "out",
      "name": "Response"
    },
    {
      "type": "serviceBus",
      "direction": "out",
      "name": "ServiceBusMessage",
      "queueName": "%ServiceBusQueueName%",
      "connection": "ServiceBusConnection"
    }
  ]
}
